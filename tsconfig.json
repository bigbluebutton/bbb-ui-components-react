{
  "compilerOptions": {
    "outDir": "./dist/",
    "declarationDir": "./dist/types",
    "module": "es6",
    "target": "es2017",
    "jsx": "react",
    "rootDir": "./src",
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "declaration": true,
    "skipLibCheck": true,
    "emitDeclarationOnly": false,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
  },
  "exclude": ["**/*.stories.tsx", "**/*.stories.ts", "node_modules", "dist"]
}
